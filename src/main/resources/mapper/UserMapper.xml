<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.orange.server.mapper.UserMapper">
    
    <resultMap id="BaseResultMap" type="com.orange.server.entity.User">
        <id column="id" property="id" />
        <result column="username" property="username" />
        <result column="phone" property="phone" />
        <result column="role_name" property="roleName" />
        <result column="department_name" property="departmentName" />
        <result column="status" property="status" />
        <result column="password" property="password" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>
    
    <select id="findByUsernameAndPassword" resultMap="BaseResultMap">
        SELECT * FROM sys_user WHERE username = #{username} AND password = #{password}
    </select>
    
    <select id="findByUsernameContaining" resultMap="BaseResultMap">
        SELECT * FROM sys_user WHERE username LIKE CONCAT('%', #{username}, '%')
    </select>
    
    <select id="findByRoleNameContaining" resultMap="BaseResultMap">
        SELECT * FROM sys_user WHERE role_name LIKE CONCAT('%', #{roleName}, '%')
    </select>
    
    <select id="findByDepartmentNameContaining" resultMap="BaseResultMap">
        SELECT * FROM sys_user WHERE department_name LIKE CONCAT('%', #{departmentName}, '%')
    </select>
    
</mapper>