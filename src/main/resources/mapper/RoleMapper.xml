<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.orange.server.mapper.RoleMapper">
    
    <resultMap id="BaseResultMap" type="com.orange.server.entity.Role">
        <id column="id" property="id" />
        <result column="role_name" property="roleName" />
        <result column="role_code" property="roleCode" />
        <result column="status" property="status" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>
    
    <select id="findByRoleNameContaining" resultMap="BaseResultMap">
        SELECT * FROM sys_role WHERE role_name LIKE CONCAT('%', #{roleName}, '%')
    </select>
    
    <select id="findByStatus" resultMap="BaseResultMap">
        SELECT * FROM sys_role WHERE status = #{status}
    </select>
    
</mapper>